{
  "name": "mojimoto-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Client SDK and framework component libraries for the Mojimoto headless CMS.",
  "author": "Your Ikigai Ltd",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "dev": "pnpm -r --parallel --filter \"./packages/**\" run dev",
    "test": "pnpm -r --filter \"./packages/**\" run test",
    "typecheck": "pnpm -r --filter \"./packages/**\" run typecheck",
    "lint": "pnpm -r --filter \"./packages/**\" run lint --if-present",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules/.cache",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
